# ── AI Provider ──────────────────────────────────────────────
# Option A: Euri API (OpenAI-compatible, no AWS quota issues)
USE_EURI=true
EURI_API_KEY=your-euri-api-key
EURI_BASE_URL=https://api.euron.one/api/v1/euri
EURI_EMBEDDING_MODEL=text-embedding-3-small
EURI_LLM_MODEL=gpt-4o-mini

# Option B: AWS Bedrock (requires model access approval)
# USE_EURI=false
# BEDROCK_EMBEDDING_MODEL_ID=cohere.embed-english-v3
# BEDROCK_LLM_MODEL_ID=apac.amazon.nova-lite-v1:0

# ── Vector Database ───────────────────────────────────────────
# Option A: Pinecone (free tier — recommended for demos)
VECTOR_DB=pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=legalrag
EMBED_DIMENSIONS=1536
EMBED_NORMALIZE=true

# Option B: AWS OpenSearch (self-hosted, ~$30-50/mo for t3.small)
# VECTOR_DB=opensearch
# OPENSEARCH_ENDPOINT=https://your-domain.es.amazonaws.com
# OPENSEARCH_INDEX=legal-docs
# OPENSEARCH_MASTER_USER=admin
# OPENSEARCH_MASTER_PASSWORD=your-password

# ── AWS (for S3 document storage + DynamoDB dedup) ────────────
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=your-account-id
S3_BUCKET_NAME=legal-rag-documents-your-account-id

# ── DynamoDB Tables ───────────────────────────────────────────
DEDUP_TABLE=legalrag-dedup
SESSIONS_TABLE=legalrag-sessions

# ── Retrieval Config ──────────────────────────────────────────
TOP_K_RETRIEVE=15
TOP_N_FINAL=5
SEMANTIC_WEIGHT=0.6
KEYWORD_WEIGHT=0.4

# ── Generation ────────────────────────────────────────────────
MAX_TOKENS=2048
TEMPERATURE=0.1

# ── Cache (optional) ──────────────────────────────────────────
ELASTICACHE_URL=redis://localhost:6379
CACHE_ENABLED=false

# ── App ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_GUARDRAILS=false
